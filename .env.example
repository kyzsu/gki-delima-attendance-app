# Copy to .env for local development (loaded via node --env-file-if-exists).
# On Vercel, set these in Project Settings → Environment Variables instead.

# Supabase Postgres — use the POOLED connection string (Supavisor, port 6543).
# Supabase dashboard → Connect → Transaction pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Long random string; tokens are HS256-signed with this. Required in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Demo mode: in-range geolocation without GPS + signup auto-approval.
# Defaults: ON in development, OFF in production.
# GKI_DEMO_MODE=false

# Used by `npm run db:setup` when seeding the admin account.
# ADMIN_EMAIL=admin@gkidelima.org
# ADMIN_PASSWORD=

# ── Frontend (Vite) ──────────────────────────────────────────────
# Mapbox PUBLIC token (starts with pk.) for the real geofence map on the
# check-in/out screens. Create one at https://account.mapbox.com/access-tokens/
# and restrict it by URL. Without it, the screens show the stylized map
# fallback. Vite only exposes VITE_-prefixed vars to the browser.
# VITE_MAPBOX_TOKEN=pk....
